{
  "version": 1,
  "scope": "codex-starter runtime authority maintenance",
  "owners": [
    {
      "id": "starter_agents",
      "path": "codex-starter/AGENTS.md",
      "allowed_sections": [
        "Scope And Precedence",
        "Product Defaults",
        "Route Intents",
        "Authority Map",
        "Top-Level Guardrails"
      ],
      "forbidden_patterns": [
        "## Read Order",
        "## Sources of truth",
        "## Output Contract",
        "## Structured Result",
        "## Runtime Entrypoints",
        "context/startup.mjs",
        "context/session.mjs",
        "context/task-overview.mjs",
        "governance/writeback.mjs",
        "governance/audit.mjs",
        "runtime/state.mjs"
      ]
    },
    {
      "id": "routing_policy",
      "path": "codex-starter/.codex/policies/routing-policy.md",
      "required_terms": [
        "technical_manager",
        "QC Gate",
        "Submit Gate"
      ]
    },
    {
      "id": "skills",
      "path_prefix": "codex-starter/.codex/skills/",
      "required_sections_any_of": [
        "## Read Order",
        "## Sources of truth"
      ]
    },
    {
      "id": "agents",
      "path_prefix": "codex-starter/.codex/agents/",
      "required_terms": [
        "developer_instructions"
      ]
    }
  ],
  "duplicate_rules": [
    {
      "id": "no_read_order_outside_skills",
      "pattern": "## Read Order",
      "allowed_paths": [
        "codex-starter/.codex/skills/"
      ]
    },
    {
      "id": "no_structured_result_outside_agents",
      "pattern": "## Structured Result",
      "allowed_paths": [
        "codex-starter/.codex/agents/",
        "codex-starter/.codex/skills/"
      ]
    }
  ],
  "authority_keywords": [
    {
      "keyword": "validation-profile.json",
      "authoritative_paths": [
        "codex-starter/AGENTS.md",
        "codex-starter/.codex/policies/routing-policy.md",
        "codex-starter/.codex/skills/",
        "codex-starter/.codex/agents/",
        "codex-starter/.codex/context/project-profile.md"
      ]
    }
  ]
}
